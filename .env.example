# Auth0 (v4 SDK)
AUTH0_SECRET=
AUTH0_BASE_URL=http://localhost:3000
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=

# Supabase (optional, in-memory fallback if unset)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_PASSWORD=
SUPABASE_POOLER_HOST=aws-1-us-east-2.pooler.supabase.com

# AI (optional, template fallback if unset)
ANTHROPIC_API_KEY=

# Resend (optional, email skipped if unset)
RESEND_API_KEY=
RESEND_FROM_EMAIL=ChronoSplit <onboarding@resend.dev>

# Sentry (optional)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
